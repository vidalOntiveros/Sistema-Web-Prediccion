# Copia este archivo a .env (para docker-compose) y/o a .env.local dentro de cada
# app (para desarrollo nativo). Ver docs/10-estructura-monorepo.md §4.

# --- Base de datos ---
# host "localhost" en desarrollo nativo, "db" (nombre del servicio) dentro de docker-compose
DATABASE_URL=postgresql://prediccion:prediccion@localhost:5432/prediccion
POSTGRES_USER=prediccion
POSTGRES_PASSWORD=prediccion
POSTGRES_DB=prediccion

# --- Auth (apps/api) ---
JWT_SECRET=changeme
JWT_EXPIRES_IN=7200

# --- Servicio ML (apps/api -> apps/ml) ---
# host "localhost" en desarrollo nativo, "ml" dentro de docker-compose
ML_SERVICE_URL=http://localhost:8000
ML_INTERNAL_API_KEY=changeme
ML_REQUEST_TIMEOUT_MS=8000

# --- apps/ml ---
# debe coincidir con ML_INTERNAL_API_KEY de arriba
INTERNAL_API_KEY=changeme

# --- apps/web (BFF) ---
# host "localhost" en desarrollo nativo, "api" dentro de docker-compose
NEST_API_URL=http://localhost:3000
